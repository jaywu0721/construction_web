rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // 專案列表 - 允許無限制讀寫
    match /projectList/{document} {
      allow read, write: if true;
    }
    
    // 專案數據 - 更精確的路徑匹配
    match /projects/{projectId} {
      // 允許讀取項目文檔
      allow read: if true;
      allow write: if true;
      
      // 集合下的所有文檔
      match /{collection}/{document} {
        allow read: if true;
        allow write: if true;
      }
    }
    
    // 連接狀態集合 - 用於監控連接
    match /connectionStatus/{document} {
      allow read, write: if true;
    }
    
    // 測試連接集合
    match /_test/{document} {
      allow read, write: if true;
    }
    
    // 禁用其他未明確允許的路徑
    match /{restPath=**} {
      allow read, write: if false;
    }
  }
}